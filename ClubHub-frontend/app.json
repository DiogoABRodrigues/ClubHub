{
  "expo": {
    "name": "A.D.E.C.A.S",
    "slug": "ADECAS",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/transparant.png",
      "resizeMode": "contain",
      "backgroundColor": "#800000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#800000",
        "foregroundImage": "./assets/1024_foreground_380.png",
        "monochromeImage": "./assets/mono.png"
      },
      "softwareKeyboardLayoutMode": "pan",
      "notification": {
        "icon": "./assets/mono.png",
        "color": "#800000"
      },
      "googleServicesFile": "./google-services.json",
      "predictiveBackGestureEnabled": false,
      "package": "com.x13dean13.A.D.E.C.A.S",
      "permissions": [
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "@react-native-community/datetimepicker",
      "./plugins/androidFixes",
      [
        "expo-build-properties",
        {
          "android": {
            "manifestQueries": {}
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "BACKEND_URI": "https://clubhub-c8u0.onrender.com:3000",
      "eas": {
        "projectId": "2118d1ae-beb4-4503-a7ab-106eab98fb24"
      }
    },
    "owner": "13dean13"
  }
}
