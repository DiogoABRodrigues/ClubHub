{
  "expo": {
    "name": "A.D.E.C.A.S",
    "slug": "ADECAS",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/transparant.png",
      "resizeMode": "contain",
      "backgroundColor": "#800000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#800000",
        "foregroundImage": "./assets/1024_foreground_380.png",
        "monochromeImage": "./assets/mono.png"
      },
      "softwareKeyboardLayoutMode": "pan",
      "googleServicesFile": "./google-services.json",
      "predictiveBackGestureEnabled": false,
      "allowBackup": false,
      "package": "com.x13dean13.A.D.E.C.A.S",
      "permissions": [
        "POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "./plugins/androidFixes",
      [
        "expo-build-properties",
        {
          "android": {
            "manifestQueries": {}
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "BACKEND_URI": "https://clubhub-c8u0.onrender.com",
      "eas": {
        "projectId": "52c0553d-0cbd-47f4-a4d5-be8489e3e9ef"
      }
    },
    "owner": "13dean"
  }
}
