{
  "name": "clubhub-frontend",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs');const p='node_modules/react-native/node_modules/react-native';if(fs.existsSync(p)){fs.rmSync(p,{recursive:true,force:true});console.log('Removed duplicate react-native');}\"",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand tests/unit",
    "test:integration": "jest --runInBand tests/integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --runInBand --coverage",
    "test:e2e": "maestro test .maestro"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/cli-server-api": "^20.1.3",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-firebase/messaging": "^24.0.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.96.0",
    "axios": "^1.13.6",
    "expo": "~55.0.26",
    "expo-build-properties": "~55.0.14",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-dev-client": "~55.0.35",
    "expo-device": "~55.0.17",
    "expo-file-system": "~55.0.22",
    "expo-font": "~55.0.8",
    "expo-image-picker": "~55.0.20",
    "expo-linking": "~55.0.15",
    "expo-modules-core": "^55.0.25",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "lucide-react-native": "^1.7.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.7.4",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.4",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/android/"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.styles.{ts,tsx}",
      "!src/models/**",
      "!src/theme/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "html",
      "lcov"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 2,
        "functions": 2,
        "lines": 3,
        "statements": 3
      }
    }
  },
  "private": true,
  "overrides": {
    "js-yaml": "^4.1.2",
    "xcode": {
      "uuid": "^11.1.1"
    },
    "react-native": "0.83.6"
  }
}
